# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (use Supabase pooler on port 6543 with ?pgbouncer=true for serverless)
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"

# Resend
RESEND_API_KEY=re_your_api_key
ADMIN_EMAIL=contact@yourdomain.com

# Site (set to your Netlify URL in production)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
